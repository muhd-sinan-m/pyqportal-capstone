SECRET_KEY=your-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-minimum-32-characters-here
FLASK_ENV=production

# AWS RDS PostgreSQL
DATABASE_URL=postgresql://username:password@your-rds-endpoint:5432/pyqportal

# AWS S3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=pyqportal-bucket

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Admin
ADMIN_USER=admin
ADMIN_PASS=changeme123